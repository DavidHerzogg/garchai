{
  "expo": {
    "name": "GARCH AI",
    "slug": "garch-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Garch_Ai_APP_Logo.png",
    "scheme": "garchai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Garch_Ai_APP_Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.garchai.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Garch_Ai_APP_Logo.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.garchai.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Garch_Ai_APP_Logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@clerk/expo",
      "expo-asset",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
